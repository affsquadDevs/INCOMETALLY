{
  "name": "next-blog-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate:all && npm run validate:tax && next build",
    "validate:tax": "node --experimental-strip-types scripts/validate-tax-data.ts",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "ci": "npm run lint && npm run format:check && npm run test:run",
    "add:country": "tsx scripts/addCountry.ts",
    "generate:robots": "node scripts/generate-robots.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:favicon": "node scripts/generate-favicon.js",
    "generate:all": "npm run generate:robots && npm run generate:sitemap && npm run generate:favicon"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.31",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.0.0",
    "tailwindcss": "^3.3.5",
    "to-ico": "^1.1.5",
    "typescript": "^5.2.2",
    "vitest": "^4.0.16"
  }
}
